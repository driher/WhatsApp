"use client";

import {
  useEffect,
  useMemo,
  useRef,
  useState,
} from "react";

import {
  io,
  Socket,
} from "socket.io-client";

/* =====================================================
   CONFIG
===================================================== */

const SOCKET_URL =
  process.env.NEXT_PUBLIC_SOCKET_URL ||
  "https://motor-beverage-aware-noticed.trycloudflare.com";

const BASE_URL =
  process.env.NEXT_PUBLIC_SOCKET_URL ||
  "https://motor-beverage-aware-noticed.trycloudflare.com";

/* =====================================================
   HELPERS
===================================================== */

const formatTime = () =>
  new Date().toLocaleTimeString(
    "id-ID",
    {
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    }
  );

function renderTextWithLinks(
  text: string
) {
  const urlRegex =
    /(https?:\/\/[^\s]+)/g;

  return text
    .split(urlRegex)
    .map((part, index) => {

      if (
        /^https?:\/\/[^\s]+$/.test(
          part
        )
      ) {
        return (
          <a
            key={index}
            href={part}
            target="_blank"
            rel="noopener noreferrer"
            className="
              text-blue-600
              underline
              break-all
            "
          >
            {part}
          </a>
        );
      }

      return part;
    });
}

/* =====================================================
   TYPES
===================================================== */

type MessageType =
  | "text"
  | "image"
  | "video"
  | "audio"
  | "sticker"
  | "document"
  | "contact"
  | "location"
  | "reaction"
  | "deleted";

interface LinkPreview {
  url?: string;
  title?: string;
  description?: string;
  image?: string;
}

interface Message {
  id: string;
  jid: string;

  senderName?: string;
  groupName?: string;

  text?: string;
  mediaUrl?: string | null;

  linkPreview?: LinkPreview;

  type: MessageType;

  direction:
    | "in"
    | "out";

  time?: string;
}

/* =====================================================
   PAGE
===================================================== */

export default function Home() {

  /* =====================================================
     STATE
  ===================================================== */

  const [messages, setMessages] =
    useState<Message[]>([]);

  const [status, setStatus] =
    useState("DISCONNECTED");

  const [activeChat, setActiveChat] =
    useState<string | null>(null);

  const [input, setInput] =
    useState("");

  const [showSidebar, setShowSidebar] =
    useState(true);

  const [newMessageAlert, setNewMessageAlert] =
    useState(false);

  const [newSenderName, setNewSenderName] =
    useState("");

  const [selectionMode, setSelectionMode] =
    useState(false);

  const [
    selectedMessages,
    setSelectedMessages,
  ] =
    useState<string[]>([]);

  /* =====================================================
     REFS
  ===================================================== */

  const socketRef =
    useRef<Socket | null>(
      null
    );

  const bottomRef =
    useRef<HTMLDivElement | null>(
      null
    );

  const chatBodyRef =
    useRef<HTMLDivElement | null>(
      null
    );

  const activeChatRef =
    useRef<string | null>(
      null
    );

  const textareaRef =
    useRef<HTMLTextAreaElement | null>(
      null
    );

  const longPressTimer =
    useRef<NodeJS.Timeout | null>(
      null
    );

  /* =====================================================
     ACTIVE CHAT REF
  ===================================================== */

  useEffect(() => {

    activeChatRef.current =
      activeChat;

  }, [activeChat]);

  /* =====================================================
     SOCKET INIT
  ===================================================== */

  useEffect(() => {

    if (
      socketRef.current
    ) {
      return;
    }

    const socket = io(
      SOCKET_URL,
      {
        transports: [
          "websocket",
        ],
        reconnection: true,
      }
    );

    socketRef.current =
      socket;

    /* CONNECT */

    socket.on(
      "connect",
      () => {

        console.log(
          "✅ SOCKET CONNECTED"
        );

        setStatus(
          "CONNECTED"
        );
      }
    );

    /* DISCONNECT */

    socket.on(
      "disconnect",
      () => {

        console.log(
          "❌ SOCKET DISCONNECTED"
        );

        setStatus(
          "DISCONNECTED"
        );
      }
    );

    /* STATUS */

    socket.on(
      "status",
      (
        value: string
      ) => {

        setStatus(
          value
        );
      }
    );

    /* HISTORY */

    socket.on(
      "message_history",
      (
        history: Message[]
      ) => {

        setMessages(
          (prev) => {

            const map =
              new Map<
                string,
                Message
              >();

            [
              ...prev,
              ...history,
            ].forEach(
              (
                msg
              ) => {

                map.set(
                  msg.id,
                  msg
                );
              }
            );

            return Array.from(
              map.values()
            );
          }
        );
      }
    );

    /* NEW MESSAGE */

socket.on(
  "message",
  (data: Message) => {

    const el =
      chatBodyRef.current;

    let isBottom = true;

    if (el) {
      isBottom =
        el.scrollHeight -
          el.scrollTop -
          el.clientHeight <
        120;
    }

    setMessages((prev) => {

      const exists =
        prev.some(
          (m) =>
            m.id === data.id
        );

      if (exists) {
        return prev;
      }

      return [
        ...prev,
        data,
      ];
    });

    const isCurrentChat =
      data.jid ===
      activeChatRef.current;

    if (
      isCurrentChat &&
      isBottom
    ) {

      setTimeout(() => {
        bottomRef.current?.scrollIntoView({
          behavior: "smooth",
        });
      }, 100);

      setNewMessageAlert(false);
      setNewSenderName("");

    } else {

      setNewMessageAlert(true);

      setNewSenderName(
        data.groupName ||
        data.senderName ||
        "Unknown"
      );
    }
  }
);

/* DELETE SYNC */

socket.on(
  "messages_deleted",
  (ids: string[]) => {

    setMessages((prev) =>
      prev.filter(
        (msg) =>
          !ids.includes(msg.id)
      )
    );
  }
);
    return () => {

      socket.disconnect();

      socketRef.current =
        null;
    };

  }, []);

  /* =====================================================
     GROUPED CHATS
  ===================================================== */

  const groupedChats =
    useMemo(() => {

      return messages.reduce(
        (
          acc: Record<
            string,
            Message[]
          >,
          msg
        ) => {

          if (
            !acc[msg.jid]
          ) {
            acc[msg.jid] =
              [];
          }

          acc[msg.jid].push(
            msg
          );

          return acc;

        },
        {}
      );

    }, [messages]);

  /* =====================================================
     ACTIVE CHAT
  ===================================================== */

  const activeMessages =
    activeChat
      ? groupedChats[
          activeChat
        ] || []
      : [];

  /* =====================================================
     AUTO SELECT FIRST CHAT
  ===================================================== */

  useEffect(() => {

    if (
      !activeChat &&
      Object.keys(
        groupedChats
      ).length > 0
    ) {

      setActiveChat(
        Object.keys(
          groupedChats
        )[0]
      );
    }

  }, [
    groupedChats,
    activeChat,
  ]);

  /* =====================================================
     AUTO SCROLL
  ===================================================== */

  useEffect(() => {

    if (
      !activeChat
    ) {
      return;
    }

    setTimeout(
      () => {

        bottomRef.current?.scrollIntoView(
          {
            behavior:
              "auto",
          }
        );

      },
      50
    );

  }, [
    activeChat,
    activeMessages.length,
  ]);

    /* =====================================================
     AUTO RESIZE TEXTAREA
  ===================================================== */

  useEffect(() => {

    const textarea =
      textareaRef.current;

    if (!textarea) {
      return;
    }

    textarea.style.height =
      "auto";

    const maxHeight =
      96;

    textarea.style.height =
      Math.min(
        textarea.scrollHeight,
        maxHeight
      ) + "px";

    textarea.style.overflowY =
      textarea.scrollHeight >
      maxHeight
        ? "auto"
        : "hidden";

  }, [input]);

  /* =====================================================
     LONG PRESS SELECT
  ===================================================== */

  const handleLongPressStart =
    (
      id: string
    ) => {

      longPressTimer.current =
        setTimeout(
          () => {

            setSelectionMode(
              true
            );

            setSelectedMessages(
              [id]
            );

          },
          1200
        );
    };

  const handleLongPressEnd =
    () => {

      if (
        longPressTimer.current
      ) {

        clearTimeout(
          longPressTimer.current
        );

        longPressTimer.current =
          null;
      }
    };

  /* =====================================================
     TOGGLE SELECT
  ===================================================== */

  const toggleSelectMessage =
    (
      id: string
    ) => {

      setSelectedMessages(
        (
          prev
        ) => {

          if (
            prev.includes(
              id
            )
          ) {

            return prev.filter(
              (
                x
              ) =>
                x !== id
            );
          }

          return [
            ...prev,
            id,
          ];
        }
      );
    };

  /* =====================================================
     CANCEL SELECTION
  ===================================================== */

  const cancelSelection =
    () => {

      setSelectionMode(
        false
      );

      setSelectedMessages(
        []
      );
    };

  /* =====================================================
     DELETE PERMANENT
  ===================================================== */

  const deleteSelectedMessages =
  async () => {

    if (
      selectedMessages.length ===
      0
    ) {
      return;
    }

    try {

      await fetch(
        `${BASE_URL}/api/messages/delete-for-all`,
        {
          method:
            "POST",

          headers: {
            "Content-Type":
              "application/json",
          },

          body:
            JSON.stringify(
              {
                ids:
                  selectedMessages,
              }
            ),
        }
      );

    } catch (err) {

      console.error(
        err
      );
    }

    setSelectedMessages(
      []
    );

    setSelectionMode(
      false
    );
  };
  /* =====================================================
     SEND MESSAGE
  ===================================================== */

  const sendMessage =
    () => {

      if (
        !activeChat
      ) {
        return;
      }

      if (
        !input.trim()
      ) {
        return;
      }

      socketRef.current?.emit(
        "send_message",
        {
          jid:
            activeChat,

          text:
            input.trim(),
        }
      );

      setInput("");

      if (
        textareaRef.current
      ) {

        textareaRef.current.style.height =
          "48px";
      }
    };

  /* =====================================================
     LAST MESSAGE
  ===================================================== */

  const getLastMessage =
    (
      jid: string
    ) => {

      const chat =
        groupedChats[
          jid
        ];

      if (
        !chat ||
        chat.length === 0
      ) {
        return null;
      }

      return chat[
        chat.length - 1
      ];
    };

  /* =====================================================
     SCROLL TO NEW MESSAGE
  ===================================================== */

  const jumpToLatestMessage =
    () => {

      const targetChat =
        Object.keys(
          groupedChats
        ).find(
          (
            jid
          ) => {

            const lastMsg =
              groupedChats[
                jid
              ]?.[
                groupedChats[
                  jid
                ].length - 1
              ];

            return (
              (
                lastMsg?.groupName ||
                lastMsg?.senderName
              ) ===
              newSenderName
            );
          }
        );

      if (
        targetChat
      ) {

        setActiveChat(
          targetChat
        );

        if (
          window.innerWidth <
          768
        ) {

          setShowSidebar(
            false
          );
        }

        setTimeout(
          () => {

            bottomRef.current?.scrollIntoView(
              {
                behavior:
                  "smooth",
              }
            );

          },
          150
        );
      }

      setNewMessageAlert(
        false
      );

      setNewSenderName(
        ""
      );
    };

  /* =====================================================
     RETURN
  ===================================================== */

  return (
  <main className="h-[100svh] flex flex-col bg-[#111b21] overflow-hidden">

  <div className="flex flex-1 min-h-0 w-full relative">

    {/* =====================================================
        SIDEBAR
    ===================================================== */}

    <div
      className={`
        bg-white
        border-r
        border-gray-200
        flex
        flex-col

        fixed
        md:relative

        z-30

        h-full
        w-full
        max-w-[320px]
        md:w-[350px]

        transition-transform
        duration-300

        ${
          showSidebar
            ? "translate-x-0"
            : "-translate-x-full"
        }

        md:translate-x-0
      `}
    >

      {/* HEADER */}

      <div
        className="
          bg-[#202c33]
          text-white
          p-4
          border-b
          border-[#2f3b43]
        "
      >

        <div
          className="
            flex
            items-center
            justify-between
          "
        >

          <div>

            <h1 className="font-bold text-lg">
              WA Hotline Relay
            </h1>

            <p
              className="
                text-xs
                text-gray-300
                mt-1
              "
            >
              {
                Object.keys(
                  groupedChats
                ).length
              }{" "}
              chats
            </p>

          </div>

          <div
            className={`
              text-xs
              px-3
              py-1
              rounded-full
              font-semibold

              ${
                status ===
                "CONNECTED"
                  ? "bg-green-100 text-green-700"
                  : "bg-red-100 text-red-700"
              }
            `}
          >
            {status}
          </div>

        </div>

      </div>

      {/* CHAT LIST */}

      <div
        className="
          flex-1
          overflow-y-auto
          min-h-0
        "
      >

        {Object.keys(
          groupedChats
        ).length === 0 && (

          <div
            className="
              p-5
              text-sm
              text-gray-500
            "
          >
            Belum ada pesan masuk
          </div>

        )}

        {Object.keys(
          groupedChats
        ).map((jid) => {

          const lastMsg =
            getLastMessage(
              jid
            );

          return (

            <div
              key={jid}

              onClick={() => {

                setActiveChat(
                  jid
                );

                setNewMessageAlert(
                  false
                );

                setNewSenderName(
                  ""
                );

                if (
                  window.innerWidth <
                  768
                ) {

                  setShowSidebar(
                    false
                  );
                }
              }}

              className={`
                p-4
                border-b
                cursor-pointer
                hover:bg-gray-100
                transition

                ${
                  activeChat ===
                  jid
                    ? "bg-[#f0f2f5]"
                    : "bg-white"
                }
              `}
            >

              <div
                className="
                  flex
                  justify-between
                  gap-2
                "
              >

                <div
                  className="
                    flex-1
                    min-w-0
                  "
                >

                  <p
                    className="
                      font-semibold
                      text-sm
                      truncate
                      text-black
                    "
                  >
                    {
                      lastMsg?.groupName ||
                      lastMsg?.senderName ||
                      jid
                    }
                  </p>

                  <p
                    className="
                      text-xs
                      text-gray-500
                      truncate
                      mt-1
                    "
                  >

                    {lastMsg?.text ||

                      (
                        lastMsg?.type ===
                        "image"
                          ? "📷 Image"
                          : lastMsg?.type ===
                            "video"
                          ? "🎥 Video"
                          : lastMsg?.type ===
                            "audio"
                          ? "🎵 Audio"
                          : lastMsg?.type ===
                            "sticker"
                          ? "😀 Sticker"
                          : "[MEDIA]"
                      )}

                  </p>

                </div>

                <div
                  className="
                    text-[10px]
                    text-gray-400
                    whitespace-nowrap
                  "
                >
                  {
                    lastMsg?.time ||
                    formatTime()
                  }
                </div>

              </div>

            </div>

          );
        })}

      </div>

    </div>

    {/* =====================================================
        MOBILE OVERLAY
    ===================================================== */}

    {showSidebar && (

      <div
        onClick={() =>
          setShowSidebar(
            false
          )
        }

        className="
          fixed
          inset-0
          bg-black/40
          z-20
          md:hidden
        "
      />

    )}

    {/* =====================================================
        CHAT AREA
    ===================================================== */}

    <div
      className="
        flex-1
        min-h-0
        flex
        flex-col
        bg-[#efeae2]
        relative
        overflow-hidden
      "
    >

      {/* CHAT HEADER */}

      <div
        className="
          bg-[#202c33]
          text-white
          p-3
          shadow-md
          flex
          items-center
          gap-3
        "
      >

        <button
          onClick={() =>
            setShowSidebar(
              true
            )
          }

          className="
            md:hidden
            text-2xl
            leading-none
          "
        >
          ☰
        </button>

        <div
          className="
            w-10
            h-10
            rounded-full
            bg-gray-500
            flex
            items-center
            justify-center
            shrink-0
          "
        >
          👤
        </div>

        <div
          className="
            min-w-0
            flex-1
          "
        >

          <p
            className="
              font-semibold
              truncate
            "
          >
            {
              activeMessages?.[0]
                ?.groupName ||
              activeMessages?.[0]
                ?.senderName ||
              activeChat ||
              "Pilih Chat"
            }
          </p>

          <p
            className="
              text-xs
              text-gray-300
            "
          >
            Online
          </p>

        </div>

      </div>

      {/* =====================================================
          SELECTION TOOLBAR
      ===================================================== */}

      {selectionMode && (

        <div
          className="
            bg-red-50
            border-b
            p-2
            flex
            gap-2
          "
        >

          <button
            onClick={
              deleteSelectedMessages
            }

            className="
              bg-red-600
              text-white
              px-3
              py-1
              rounded
            "
          >
            Hapus (
            {
              selectedMessages.length
            }
            )
          </button>

          <button
            onClick={
              cancelSelection
            }

            className="
              bg-gray-300
              px-3
              py-1
              rounded
            "
          >
            Batal
          </button>

        </div>

      )}

      {/* =====================================================
          CHAT BODY
      ===================================================== */}

      <div
        ref={chatBodyRef}

        className="
          flex-1
          overflow-y-auto
          p-3
          md:p-5
          space-y-3
          bg-[#efeae2]
        "
      >
              {activeMessages.length === 0 && (

          <div
            className="
              h-full
              flex
              items-center
              justify-center
              text-gray-500
              text-sm
            "
          >
            Pilih chat untuk mulai melihat pesan
          </div>

        )}

        {activeMessages.map((msg) => (
  <div
    key={msg.id}
    className={`flex ${
      msg.direction === "in" ? "justify-start" : "justify-end"
    }`}
  >
    {/* BUBBLE */}
    <div
      onMouseDown={() => handleLongPressStart(msg.id)}
      onMouseUp={handleLongPressEnd}
      onMouseLeave={handleLongPressEnd}
      onTouchStart={() => handleLongPressStart(msg.id)}
      onTouchEnd={handleLongPressEnd}
      onClick={() => {
        if (selectionMode) toggleSelectMessage(msg.id);
      }}
      className={`
        relative
        max-w-[75%]
        px-3
        py-2
        rounded-2xl
        text-sm
        break-words
        cursor-pointer
        select-none
        transition

        ${
          msg.direction === "in"
            ? "bg-white text-black rounded-tl-md"
            : "bg-[#d9fdd3] text-black rounded-tr-md"
        }

        ${
          selectedMessages.includes(msg.id)
            ? "ring-2 ring-green-500"
            : ""
        }
      `}
    >
      {/* SELECTION CHECKBOX */}
      {selectionMode && (
        <div className="absolute top-1 left-1">
          <input
            type="checkbox"
            checked={selectedMessages.includes(msg.id)}
            readOnly
          />
        </div>
      )}

      {/* =========================
          DELETED OVERRIDE (WA STYLE)
      ========================= */}
      {msg.type === "deleted" ? (
        <i className="text-gray-500 text-sm">
          Pesan ini telah dihapus
        </i>
      ) : (
        <>
          {/* SENDER */}
          <p className="text-[12px] font-semibold text-gray-600 mb-1">
            {msg.senderName || "User"}
          </p>



          {/* =========================
              MEDIA PREVIEW BLOCK
          ========================= */}


       {/* IMAGE */}
          {msg.type === "image" && msg.mediaUrl && (
            <img
              src={msg.mediaUrl}
              alt="image"
              loading="lazy"
              className="rounded-lg max-w-full max-h-[400px] object-cover mb-2"
              onError={(e) => {
                e.currentTarget.style.display = "none";
              }}
            />
          )}
          {/* VIDEO */}
{msg.type === "video" && msg.mediaUrl && (
  <video
    controls
    className="rounded-lg max-w-full mb-2"
  >
    <source  src={msg.mediaUrl} type="video/mp4" />
  </video>
)}

          {/* AUDIO */}
{msg.type === "audio" && msg.mediaUrl && (
  <audio
    controls
    className="w-full max-w-[280px] mb-2"
    src={msg.mediaUrl}
  />
)}

          {/* STICKER */}
          {msg.type === "sticker" && msg.mediaUrl && (
            <img
              src={msg.mediaUrl}
              className="w-24 h-24 object-contain mb-1"
              alt="sticker"
            />
          )}

          {/* LINK PREVIEW */}
          {msg.linkPreview && (
            <a
              href={msg.linkPreview.url}
              target="_blank"
              rel="noopener noreferrer"
              className="block mb-2 bg-white rounded-xl overflow-hidden border border-gray-200"
            >
              {msg.linkPreview.image && (
                <img
                  src={msg.linkPreview.image}
                  className="w-full max-h-48 object-cover"
                  alt="preview"
                />
              )}

              <div className="p-3">
                <div className="font-semibold text-sm">
                  {msg.linkPreview.title}
                </div>
                <div className="text-xs text-gray-500 mt-1">
                  {msg.linkPreview.description}
                </div>
              </div>
            </a>
          )}

          {/* TEXT */}
          {msg.text &&
            msg.type !== "deleted" &&
            msg.text !== "[STICKER]" && (
              <p className="whitespace-pre-wrap text-[14px]">
                {renderTextWithLinks(msg.text)}
              </p>
            )}

          {/* TIME */}
          <div className="flex justify-end mt-1">
            <p className="text-[10px] text-gray-400">
              {msg.time || formatTime()}
            </p>
          </div>
        </>
      )}
    </div>
  </div>
))}

        <div ref={bottomRef} />

      </div>

      {/* NEW MESSAGE ALERT */}

      {newMessageAlert && (

        <button

          onClick={
            jumpToLatestMessage
          }

          className="
            absolute
            bottom-[110px]
            md:bottom-24
            right-5
            bg-[#00a884]
            text-white
            px-4
            py-2
            rounded-full
            shadow-lg
            text-sm
            animate-bounce
            z-20
          "
        >
          {`Pesan baru dari ${newSenderName} ↓`}
        </button>

      )}

      {/* INPUT */}

      <div
        className="
          bg-[#202c33]
          p-3
        "
      >

        <div
          className="
            flex
            items-end
            gap-2
            w-full
          "
        >

          <textarea

            ref={textareaRef}

            value={input}

            rows={1}

            placeholder="Ketik pesan..."

            onChange={(e) =>
              setInput(
                e.target.value
              )
            }

            onKeyDown={(
              e
            ) => {

              if (
                window.innerWidth <
                768
              ) {
                return;
              }

              if (
                e.key ===
                  "Enter" &&
                !e.shiftKey
              ) {

                e.preventDefault();

                sendMessage();
              }
            }}

            className="
              flex-1
              min-w-0
              resize-none
              bg-white
              text-black
              rounded-3xl
              px-4
              py-3
              text-sm
              outline-none
              leading-6
              min-h-[48px]
              max-h-[96px]
              overflow-y-auto
            "
          />

          <button

            onClick={
              sendMessage
            }

            className="
              bg-[#00a884]
              hover:bg-[#06cf9c]
              text-white
              px-4
              py-3
              md:px-5
              rounded-full
              transition
              font-semibold
              shrink-0
            "
          >
            Kirim
          </button>

        </div>

      </div>

    </div>

  </div>

</main>

  );
}