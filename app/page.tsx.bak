"use client";

import { useEffect, useMemo, useRef, useState } from "react";
import { io } from "socket.io-client";

const socket = io(
  "https://valuable-footage-argument-metallica.trycloudflare.com:3000",
  {
    transports: ["websocket", "polling"],
  }
);

const formatTime = () =>
  new Date().toLocaleTimeString("id-ID", {
    hour: "2-digit",
    minute: "2-digit",
    second: "2-digit",
    hour12: false,
  });

export default function Home() {
  const [messages, setMessages] = useState<any[]>([]);
  const [status, setStatus] = useState("DISCONNECTED");
  const [activeChat, setActiveChat] = useState<string | null>(null);
  const [input, setInput] = useState("");

  const bottomRef = useRef<HTMLDivElement | null>(null);

  // ======================
  // SOCKET FIX (ANTI DUPLICATE)
  // ======================
  useEffect(() => {
    const onConnect = () => {
      console.log("Socket connected");
    };

    const onStatus = (data: any) => {
      setStatus(data);
    };

    const onMessage = (data: any) => {
      setMessages((prev) => {
        // 🔥 ANTI DUPLICATE MESSAGE
        const exists = prev.some((m) => m.id === data.id);
        if (exists) return prev;

        return [
          {
            ...data,
            direction: data.direction || "in",
          },
          ...prev,
        ];
      });
    };

    socket.on("connect", onConnect);
    socket.on("status", onStatus);
    socket.on("new_message", onMessage);

    return () => {
      socket.off("connect", onConnect);
      socket.off("status", onStatus);
      socket.off("new_message", onMessage);
    };
  }, []);

  // ======================
  // GROUP CHAT
  // ======================
  const groupedChats = useMemo(() => {
    return messages.reduce((acc: any, msg: any) => {
      if (!acc[msg.jid]) acc[msg.jid] = [];
      acc[msg.jid].push(msg);
      return acc;
    }, {});
  }, [messages]);

  const activeMessages = activeChat ? groupedChats[activeChat] || [] : [];

  // ======================
  // AUTO SCROLL
  // ======================
  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [activeMessages]);

  // ======================
  // AUTO SELECT CHAT
  // ======================
  useEffect(() => {
    if (!activeChat && Object.keys(groupedChats).length > 0) {
      setActiveChat(Object.keys(groupedChats)[0]);
    }
  }, [groupedChats]);

  // ======================
  // SEND MESSAGE (OPTIMISTIC UI)
  // ======================
  const sendMessage = () => {
    if (!input.trim() || !activeChat) return;

    const msg = {
      id: Date.now(), // 🔥 unique id penting
      jid: activeChat,
      text: input,
      senderName: "You",
      direction: "out",
      time: formatTime(),
    };

    // 🔥 langsung tampil di UI (no delay)
    setMessages((prev) => [msg, ...prev]);

    // kirim ke server
    socket.emit("send_message", msg);

    setInput("");
  };

  return (
    <main className="h-screen flex bg-[#e5ddd5]">

      {/* SIDEBAR */}
      <div className="w-1/3 bg-white border-r overflow-y-auto">
        <div className="p-3 font-bold border-b">
          Chats ({Object.keys(groupedChats).length})
        </div>

        {Object.keys(groupedChats).map((jid) => {
          const lastMsg = groupedChats[jid][0];

          return (
            <div
              key={jid}
              onClick={() => setActiveChat(jid)}
              className={`p-3 border-b cursor-pointer hover:bg-gray-100 ${
                activeChat === jid ? "bg-gray-100" : ""
              }`}
            >
              <p className="font-bold text-sm">
                {lastMsg.groupName || lastMsg.senderName}
              </p>

              <p className="text-xs text-gray-500 truncate">
                {lastMsg.text || "[MEDIA]"}
              </p>
            </div>
          );
        })}
      </div>

      {/* CHAT AREA */}
      <div className="flex-1 flex flex-col">

        {/* HEADER */}
        <div className="bg-white p-3 shadow">
          <p className="font-bold">
            {activeChat
              ? groupedChats[activeChat]?.[0]?.groupName ||
                groupedChats[activeChat]?.[0]?.senderName
              : "Pilih Chat"}
          </p>

          <p className="text-xs text-gray-500">
            Status WhatsApp: {status}
          </p>
        </div>

        {/* CHAT BODY */}
        <div className="flex-1 overflow-y-auto p-4 space-y-2">
          {activeMessages.map((msg: any) => {
            const isIncoming = msg.direction === "in";

            return (
              <div
                key={msg.id}
                className={`flex ${
                  isIncoming ? "justify-start" : "justify-end"
                }`}
              >
                <div
                  className={`max-w-[70%] p-2 rounded-lg shadow text-sm ${
                    isIncoming ? "bg-white" : "bg-green-200"
                  }`}
                >

                  {/* SENDER NAME */}
                  {isIncoming && msg.senderName && (
                    <p className="text-[11px] text-gray-500 font-medium">
                      {msg.senderName}
                    </p>
                  )}

                  {/* MESSAGE TEXT */}
                  {msg.text && (
                    <p className="whitespace-pre-wrap">{msg.text}</p>
                  )}

                  {/* TIME */}
                  <p className="text-[10px] text-gray-400 text-right mt-1">
                    {msg.time}
                  </p>
                </div>
              </div>
            );
          })}

          <div ref={bottomRef} />
        </div>

        {/* INPUT BAR */}
        <div className="p-3 bg-white border-t flex gap-2">
          <input
            value={input}
            onChange={(e) => setInput(e.target.value)}
            onKeyDown={(e) => e.key === "Enter" && sendMessage()}
            className="flex-1 border rounded-full px-4 py-2 text-sm"
            placeholder="Ketik pesan..."
          />

          <button
            onClick={sendMessage}
            className="bg-green-500 text-white px-4 rounded-full"
          >
            Kirim
          </button>
        </div>

      </div>
    </main>
  );
}